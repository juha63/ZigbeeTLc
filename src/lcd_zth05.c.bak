void init_lcd(void){
	lcd_i2c_addr = scan_i2c_addr(ZHT05_I2C_ADDR << 1);
	if (lcd_i2c_addr) {
		//pm_wait_ms(50); // LCD_INIT_DELAY()
		lcd_send_i2c_buf((u8 *) lcd_init_cmd_b14, sizeof(lcd_init_cmd_b14));
		lcd_send_i2c_buf((u8 *) lcd_init_clr_b14, sizeof(lcd_init_clr_b14));
	}
}

