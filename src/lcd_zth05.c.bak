/* 0x00 = "  "
 * 0x0b01000000 = "°Г"
 * 0x0b10000000 = " -"
 * 0x0b11000000 = "°F"
 * 0x0b00001000 = " _"
 * 0xA0 = "°C"
 * 0xC0 = " ="
 * 0xE0 = "°E"
void show_temp_symbol(u8 symbol) {
	display_buff[3] &= ~(BIT(0) | BIT(1) | BIT(2));
	if (symbol & 0x20)
		display_buff[3] |= BIT(0);
	if (symbol & 0x40)
		display_buff[3] |= BIT(1); //"-"
	if (symbol & 0x80)
		display_buff[3] |= BIT(2); // "_"
}
*/


/*0=off, 1=happy, 2=sad*/

void show_smiley(u8 state){
	display_buff[3] &= ~BIT(4);
	display_buff[3] &= ~(BIT(0) | BIT(1));

	if(state == 1) {
		display_buff[3] |= BIT(1); //Happy mouth
		display_buff[3] |= BIT(4);
	} else if(state == 2) {
		display_buff[3] |= BIT(0); //Sad mouth
		display_buff[3] |= BIT(4);
	}
}

void show_ble_symbol(bool state){
	if (state)
		display_buff[4] |= LCD_SYM_BLE;
	else 
		display_buff[4] &= ~LCD_SYM_BLE;
}

void show_battery_symbol(bool state){
	if (state)
		display_buff[3] |= LCD_SYM_BAT;
	else 
		display_buff[3] &= ~LCD_SYM_BAT;
}

